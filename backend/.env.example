# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Database (Neo4j AuraDB) ───────────────────────────────────────────────────
# Get these from console.neo4j.io → your instance → Connect → Connection details
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-instance-password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# ── Spotify ───────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://your-app.vercel.app/spotify/connect

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Email of the first superadmin — gets the role set on startup
SUPERADMIN_EMAIL=your@email.com

# ── Email (optional) ──────────────────────────────────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@grimr.app
